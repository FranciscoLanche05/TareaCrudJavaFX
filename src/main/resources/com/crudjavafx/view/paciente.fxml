<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@styles/estilos.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.crudjavafx.controller.PacienteController">

    <top>
        <HBox alignment="CENTER" styleClass="header-pane">
            <Label styleClass="titulo-label" text="Sistema de Registro de Pacientes" />
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
        </HBox>
    </top>

    <left>
        <VBox spacing="15.0" styleClass="form-pane" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <GridPane hgap="10" vgap="12">
                <columnConstraints>
                    <ColumnConstraints minWidth="100.0" prefWidth="120.0" />
                    <ColumnConstraints minWidth="180.0" prefWidth="200.0" />
                </columnConstraints>

                <Label text="Cédula:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtCedula" promptText="Ej. 1700000000" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Nombres:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="txtNombres" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Apellidos:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="txtApellidos" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Fecha Nac.:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <DatePicker fx:id="dpFechaNac" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label text="Género:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <HBox spacing="15.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
                    <fx:define>
                        <ToggleGroup fx:id="tgGenero" />
                    </fx:define>
                    <RadioButton fx:id="rbMasculino" text="Masculino" toggleGroup="$tgGenero" />
                    <RadioButton fx:id="rbFemenino" text="Femenino" toggleGroup="$tgGenero" />
                </HBox>

                <Label text="E-mail:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                <TextField fx:id="txtEmail" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                <Label text="Tipo Sangre:" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                <ComboBox fx:id="cbTipoSangre" prefWidth="200.0" promptText="Seleccionar..." GridPane.columnIndex="1" GridPane.rowIndex="7" />

                <Label text="Alergias:" GridPane.columnIndex="0" GridPane.rowIndex="8" />
                <TextArea fx:id="txtAlergias" prefHeight="60.0" prefRowCount="3" GridPane.columnIndex="1" GridPane.rowIndex="8" />

                <Label text="Estado:" GridPane.columnIndex="0" GridPane.rowIndex="9" />
                <CheckBox fx:id="chkActivo" selected="true" text="Activo" GridPane.columnIndex="1" GridPane.rowIndex="9" />
            </GridPane>

            <HBox alignment="CENTER" spacing="15.0">
                <Button fx:id="btnGuardar" onAction="#guardarPaciente" styleClass="btn-guardar" text="Guardar" />
                <Button fx:id="btnLimpiar" onAction="#limpiarFormulario" styleClass="btn-limpiar" text="Limpiar" />
                <Button fx:id="btnEliminar" onAction="#eliminarPaciente" styleClass="btn-eliminar" text="Eliminar" />
            </HBox>
        </VBox>
    </left>

    <center>
        <VBox styleClass="table-pane" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="10.0" right="20.0" top="20.0" />
            </padding>
            <TableView fx:id="tablaPacientes" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colCedula" prefWidth="90.0" text="Cédula" />
                    <TableColumn fx:id="colNombres" prefWidth="120.0" text="Nombres" />
                    <TableColumn fx:id="colApellidos" prefWidth="120.0" text="Apellidos" />
                    <TableColumn fx:id="colFechaNac" prefWidth="90.0" text="Fecha Nac." />
                    <TableColumn fx:id="colTelefono" prefWidth="90.0" text="Teléfono" />
                    <TableColumn fx:id="colTipoSangre" prefWidth="80.0" text="Sangre" />
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>